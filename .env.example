# Copy to .env (auto-loaded) or export in your shell. All are optional.
# Prefix is GA4GH_MCP_.

# --- transport ---
GA4GH_MCP_TRANSPORT=stdio            # stdio | streamable-http
GA4GH_MCP_HOST=127.0.0.1             # bind host for streamable-http
GA4GH_MCP_PORT=8000
GA4GH_MCP_HTTP_PATH=/mcp
GA4GH_MCP_STATELESS_HTTP=true        # true is friendly to serverless (Vertex/Bedrock/Cloud Run)

# --- registry ---
GA4GH_MCP_REGISTRY_BASE_URL=https://implementation-registry.ga4gh.org/api

# --- HTTP client tuning ---
GA4GH_MCP_CONNECT_TIMEOUT=5.0
GA4GH_MCP_READ_TIMEOUT=15.0
GA4GH_MCP_MAX_RETRIES=2
GA4GH_MCP_VERIFY_TLS=true

# --- caching ---
GA4GH_MCP_REGISTRY_CACHE_TTL=300     # seconds
GA4GH_MCP_LIVENESS_CACHE_TTL=30

# --- auth (see docs/auth.md) ---
# Path to a JSON auth config mapping services -> providers (secrets referenced by env-var name).
GA4GH_MCP_AUTH_CONFIG=
# Global static bearer token, sent ONLY to hosts in GA4GH_MCP_BEARER_HOSTS (comma-separated).
GA4GH_MCP_BEARER_TOKEN=
GA4GH_MCP_BEARER_HOSTS=
